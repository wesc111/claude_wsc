<Window x:Class="ChessViewer.Views.MessageDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" SizeToContent="Height" CanResize="False"
        Background="#2B2B2B"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <StackPanel Margin="24,20,24,18">
        <TextBlock Name="MessageText" Foreground="#E0E0E0" FontSize="13"
                   TextWrapping="Wrap" Margin="0,0,0,18"/>
        <Button Content="OK" Width="80" HorizontalAlignment="Right"
                Height="28" IsDefault="True" Click="OkButton_Click"/>
    </StackPanel>
</Window>
