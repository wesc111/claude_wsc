<UserControl x:Class="ChessViewer.Controls.ChessboardControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="Auto,*">
        <Border Grid.Row="0" Grid.Column="1" BorderBrush="#333" BorderThickness="2">
            <UniformGrid Name="BoardGrid" Rows="8" Columns="8"/>
        </Border>
        <UniformGrid Name="RankLabels" Grid.Row="0" Grid.Column="0" Rows="8" Columns="1"/>
        <UniformGrid Name="FileLabels" Grid.Row="1" Grid.Column="1" Rows="1" Columns="8"/>
    </Grid>
</UserControl>
