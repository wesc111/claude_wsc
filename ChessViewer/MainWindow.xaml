<Window x:Class="ChessViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ChessViewer.Controls"
        Title="Chess Viewer" Height="780" Width="860"
        Background="#2B2B2B">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left column: board + navigation + load button -->
        <StackPanel Grid.Column="0" VerticalAlignment="Top">

            <controls:ChessboardControl Board="{Binding Board}" FlipBoard="{Binding FlipBoard}" Width="560" Height="560"/>

            <!-- Navigation controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,6">
                <Button Content="|◀" Width="44" Height="32" Margin="3,0"
                        Command="{Binding GoToStartCommand}" ToolTip="Start"/>
                <Button Content="◀"  Width="44" Height="32" Margin="3,0"
                        Command="{Binding PrevMoveCommand}"  ToolTip="Previous move"/>
                <TextBlock Text="{Binding MoveStatus}" Foreground="White"
                           VerticalAlignment="Center" Margin="10,0"
                           FontSize="13" MinWidth="80" TextAlignment="Center"/>
                <Button Content="▶"  Width="44" Height="32" Margin="3,0"
                        Command="{Binding NextMoveCommand}"  ToolTip="Next move"/>
                <Button Content="▶|" Width="44" Height="32" Margin="3,0"
                        Command="{Binding GoToEndCommand}"   ToolTip="End"/>
                <Button Content="⇅"  Width="44" Height="32" Margin="10,0,3,0"
                        Command="{Binding FlipBoardCommand}" ToolTip="Flip board"/>
            </StackPanel>

            <!-- Comment panel: fixed 2-line area for the current move annotation -->
            <Border Background="#1A1A2E" BorderBrush="#555" BorderThickness="1"
                    CornerRadius="3" Margin="0,4,0,6" Height="44">
                <TextBlock Text="{Binding FormattedComment}" Foreground="#C8C8D8"
                           FontStyle="Italic" FontSize="12"
                           Margin="8,5"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Load PGN File…" Width="160" Height="30" Margin="0,0,8,0"
                        Command="{Binding LoadPgnCommand}"/>
                <Button Content="About" Width="70" Height="30"
                        Click="AboutButton_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Right column: move list -->
        <DockPanel Grid.Column="1" Margin="14,0,0,0">
            <TextBlock DockPanel.Dock="Top" Text="Moves" Foreground="White"
                       FontWeight="Bold" FontSize="14" Margin="4,0,0,8"/>
            <ListBox ItemsSource="{Binding MoveList}"
                     SelectedIndex="{Binding CurrentMoveIndex, Mode=TwoWay}"
                     Background="#1A1A2E" Foreground="#E0E0E0"
                     BorderBrush="#555" FontFamily="Consolas" FontSize="13"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4A4A8A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
